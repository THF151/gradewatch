# Generate with:
#   cargo run -- --gen-master-key
MASTER_KEY=

# Generate with:
#   cargo run -- --hash-password-b64 'admin-password'
ADMIN_USER=admin
ADMIN_PASSWORD_HASH_B64=

DATA_DIR=/data
POLL_INTERVAL_MINUTES=60
POLL_JITTER_SECONDS=120
CONCURRENCY=4
BIND_ADDR=0.0.0.0:8080
LOG_LEVEL=info

# Uni Mannheim SMTP. Use your Uni-ID and Uni-ID password here.
SMTP_HOST=exchange.uni-mannheim.de
SMTP_PORT=587
SMTP_TLS=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL=
